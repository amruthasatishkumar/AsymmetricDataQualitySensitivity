# Azure AI Foundry configuration (Entra ID auth — no API key needed)
# Copy this file to `.env` and fill in your values.
#
# Auth uses DefaultAzureCredential which will try (in order):
#   1. Environment vars (AZURE_CLIENT_ID/SECRET/TENANT) — leave unset
#   2. Managed Identity
#   3. Azure CLI (`az login`) — this is what we use locally
#   4. Visual Studio / VS Code sign-in
#
# Endpoint examples:
#   Azure OpenAI sub-endpoint: https://<resource>.openai.azure.com/
#   Foundry services endpoint: https://<resource>.services.ai.azure.com/
# Use the OpenAI one for chat completions.
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_DEPLOYMENT=gpt-4o-mini
AZURE_AI_FOUNDRY_API_VERSION=2024-08-01-preview
